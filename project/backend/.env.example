# Gmail SMTP (use an App Password, not your regular Gmail password)
# 1. Enable 2-Step Verification on your Google account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Create an app password for "Mail"
# 4. Copy the 16-character password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=gmail@gmail.com
SMTP_PASSWORD=password for 2 authentication factor
SMTP_FROM_EMAIL=gmail@gmail.com
SMTP_FROM_NAME=Neural Campus


# Optional
JWT_SECRET=change-this-to-a-random-secret


